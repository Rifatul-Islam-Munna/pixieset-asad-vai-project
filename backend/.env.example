MONGODB_URL=mongodb://127.0.0.1:27017/pixieset-asad-vai-project
ACCESS_TOKEN=replace-with-long-random-secret
ADMIN_EMAIL=test@gmail.com
ADMIN_PASSWORD=11111111

# Same OAuth 2.0 Web client ID used by frontend.
GOOGLE_CLIENT_ID=1234567890-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com

MINIO_URL=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_BUCKET=gallerista.app
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin12345
MINIO_FORCE_PATH_STYLE=false

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
IMAGE_MODEL_URL=http://127.0.0.1:8010
IMAGE_MODEL_API_KEY=change-this-to-a-long-random-secret
IMAGE_MODEL_QDRANT_COLLECTION=album_faces_insightface

# Face clustering & search thresholds (tuned for buffalo_s model).
# Lower values = more aggressive merging of same-person faces.
# Raise if different people get merged; lower if same person stays split.
FACE_CLUSTER_SIMILARITY=0.16
FACE_CLUSTER_PAIR_SIMILARITY=0.16
FACE_CLUSTER_CONFLICT_SIMILARITY=0.35
FACE_PERSON_SIMILARITY=0.16
FACE_SIDEBAR_DUPLICATE_SIMILARITY=0.22
FACE_SIDEBAR_CONFLICT_DUPLICATE_SIMILARITY=0.24
FACE_MATCH_SIMILARITY=0.32
FACE_SEARCH_SCAN_LIMIT=100000
IMAGE_UPLOAD_MAX_BYTES=921600
IMAGE_UPLOAD_MAX_WIDTH=1920
IMAGE_UPLOAD_MAX_HEIGHT=1920
